# Local dev placeholder; copy to .env and fill in from the credentials your instructor gave you.
AZURE_AI_PROJECT_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project>
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-5.5

# 学员后缀（讲师分配），决定 hosted agent / 镜像 tag 的名字。
STUDENT_SUFFIX=stu01
AGENT_NAME=research-agent-${STUDENT_SUFFIX}

# 共享 ACR（讲师提供），azd deploy 时 remoteBuild 用它。
AZURE_CONTAINER_REGISTRY_NAME=cr...
AZURE_CONTAINER_REGISTRY_ENDPOINT=cr....azurecr.io

# SP 凭据（用于 azd auth login + chat-hosted.ps1 直接 OAuth client_credentials grant）。
# chat-hosted.ps1 不依赖 az login —— 只要这 3 个 + AZURE_AI_PROJECT_ENDPOINT 填好就能拿 token。
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# 可选 — 启用真实 Bing 搜索；留空则 web_search 走 mock 兜底
BING_SEARCH_API_KEY=
# 或 Google CSE
GOOGLE_CSE_KEY=
GOOGLE_CSE_CX=

PORT=8087

