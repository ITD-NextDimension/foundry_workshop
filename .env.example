# ---------------------------------------------------------------------------
# Foundry Workshop · .env (one-time setup)
# ---------------------------------------------------------------------------
# Copy this file to .env and fill in. 学员只需填一次，整个 workshop (Lab 0/1/2/3/4)
# 所有脚本都会从这里读凭据 -- 无需重复填 azd env 或 process env。
# ---------------------------------------------------------------------------


# === [所有 Lab 必填] 共享 Foundry 项目 (讲师下发) ===========================
# Project endpoint 形如 https://<account>.services.ai.azure.com/api/projects/<project>
AZURE_AI_PROJECT_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project>

# 模型 deployment 名 (讲师指定；默认 gpt-5.5)
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-5.5

# 学员后缀 (讲师分配, 用来在共享 project 里区分各自的 hosted agent)
STUDENT_SUFFIX=stu01

# Hosted agent 名 (默认 = research-agent-<后缀>)
AGENT_NAME=research-agent-${STUDENT_SUFFIX}


# === [Lab 0/1/3 必填] 学员服务主体凭据 =====================================
# 同一组凭据用于：
#   - azd auth login --service-principal (Lab 0)
#   - azd deploy (Lab 1/3)
#   - chat-hosted.ps1 直接 OAuth2 client_credentials grant 拿 token (Lab 1/3)
#     -> 不需要 az login, 学员无 az CLI 也能用
AZURE_TENANT_ID=<tenant guid>
AZURE_CLIENT_ID=<sp appId>
AZURE_CLIENT_SECRET=<sp secret>
AZURE_SUBSCRIPTION_ID=<sub guid>


# === [Lab 1/3 必填] 共享 ACR (讲师提供) ====================================
# azd deploy 通过 ACR remote build 把镜像推到这里 (学员只有 AcrPush + Contributor)
AZURE_CONTAINER_REGISTRY_NAME=cr...
AZURE_CONTAINER_REGISTRY_ENDPOINT=cr....azurecr.io


# === [Lab 2 可选] 本地 dev server 端口 =====================================
PORT=8087


# === [Lab 2 可选] Jina Reader API key (提速 web_fetch) =====================
# 免费档已经够 demo; 想去掉 rate limit / 抓更大页可以申请, 留空走匿名档即可
JINA_API_KEY=


# ---------------------------------------------------------------------------
# Workshop 不再依赖以下 (已废弃, 不要再填):
#   BING_SEARCH_API_KEY    -> web_search 改用 DuckDuckGo HTML 端点 (免费免 key)
#   GOOGLE_CSE_KEY/CX      -> 同上
#   FOUNDRY_API_KEY        -> 只用 SP + OAuth, 不混用 api key
# ---------------------------------------------------------------------------
